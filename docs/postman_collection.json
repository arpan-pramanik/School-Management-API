{
  "info": {
    "name": "School Management API",
    "description": "APIs to manage schools and find them by geographic proximity.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Add School",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Springfield Elementary\",\n  \"address\": \"123 Fake Street, Springfield\",\n  \"latitude\": 39.7817,\n  \"longitude\": -89.6501\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/addSchool",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "addSchool"
          ]
        },
        "description": "Adds a new school to the database."
      },
      "response": []
    },
    {
      "name": "List Schools",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/listSchools?latitude=39.78&longitude=-89.65",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "listSchools"
          ],
          "query": [
            {
              "key": "latitude",
              "value": "39.78",
              "description": "User's latitude"
            },
            {
              "key": "longitude",
              "value": "-89.65",
              "description": "User's longitude"
            }
          ]
        },
        "description": "Retrieves a list of schools sorted by geographical proximity to the provided coordinates."
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://educase-two-omega.vercel.app",
      "type": "string"
    }
  ]
}
